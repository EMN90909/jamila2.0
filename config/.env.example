# ═══════════════════════════════════════════════════════════════
# Jamila Voice AI - Environment Configuration
# Copy this file to .env in the main directory and fill in your API keys
# NEVER commit .env to version control - it contains secrets!
# ═══════════════════════════════════════════════════════════════

# ─── LLM PROVIDER SELECTION ───────────────────────────────────
# Choose your AI provider: gemini, openrouter, or deepseek
LLM_PROVIDER=openrouter

# ─── MODEL CONFIGURATION ──────────────────────────────────────
# Model name depends on provider:
# - Gemini: gemini-pro, gemini-1.5-pro, gemini-1.5-flash
# - OpenRouter: openai/gpt-4o-mini, openai/gpt-4o, anthropic/claude-3.5-sonnet, meta-llama/llama-3.1-70b
# - DeepSeek: deepseek-chat, deepseek-coder
LLM_MODEL=openai/gpt-4o-mini

# ─── API KEYS (Required for chosen provider) ──────────────────
# Get your API keys from:
# - Gemini: https://aistudio.google.com/app/apikey
# - OpenRouter: https://openrouter.ai/keys
# - DeepSeek: https://platform.deepseek.com/api_keys

GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ─── OPENROUTER SPECIFIC (Optional) ───────────────────────────
# These identify your app on OpenRouter leaderboards
OPENROUTER_HTTP_REFERER=https://jamila.local
OPENROUTER_X_TITLE=Jamila Voice AI

# ─── FEATURE FLAGS ────────────────────────────────────────────
# Enable persistent chat history storage
ENABLE_CHAT_HISTORY=true
# Maximum messages to keep in context for AI (prevents token limit issues)
MAX_CHAT_HISTORY=50
